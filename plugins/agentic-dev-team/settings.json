{
  "_windows_hooks": "On Windows, invoke hooks via: hooks\\run-hook.cmd hooks/<script>.sh — the shim locates bash (PATH, Git for Windows, or WSL) and passes stdin/args/exit codes through.",
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "NotebookEdit",
      "mcp__*"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(git push *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash hooks/pre-tool-guard.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash hooks/destructive-guard.sh" },
          { "type": "command", "command": "bash hooks/pre-commit-review.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash hooks/js-fp-review.sh" },
          { "type": "command", "command": "bash hooks/token-efficiency-review.sh" },
          { "type": "command", "command": "bash hooks/eval-compliance-check.sh" },
          { "type": "command", "command": "bash hooks/tdd-guard.sh" }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          { "type": "command", "command": "bash hooks/version-check.sh" }
        ]
      }
    ]
  }
}
